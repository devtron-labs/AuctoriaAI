DATABASE_URL=postgresql://postgres:password@localhost:5432/veritas_ai

# Deployment environment.
# Controls dev-mode safety bypasses (e.g. empty-registry bypass for first-time setup).
# Values: local | development | staging | production
# Default (unset) = production — all governance gates are fully enforced.
# Set to "local" or "development" only in non-production environments.
ENV=local

